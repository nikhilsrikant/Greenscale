# Optional: use Electricity Maps at runtime if you have an API key.
# Without this, GreenScale uses the static region metadata in REGION_ENDPOINTS.
ELECTRICITY_MAPS_TOKEN=

# Scheduler weights. Increase gamma for greener placement, alpha for latency sensitivity.
SCHEDULER_ALPHA_LATENCY=0.45
SCHEDULER_BETA_COST=0.20
SCHEDULER_GAMMA_CARBON=0.25
SCHEDULER_DELTA_COLDSTART=0.10

# Hard policy: if true, the scheduler rejects regions whose predicted latency exceeds SLO.
STRICT_SLO=true

# Region/worker registry is supplied as JSON to keep the MVP cloud-agnostic.
# docker-compose overrides this with the service names.
REGION_ENDPOINTS=[]

# Local Grafana login for Milestone 3 observability.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=greenscale
